{
  "providers": ["node", "php"],
  "phases": {
    "setup": {
      "nixPkgs": ["php84", "php84Packages.composer", "nodejs_20"]
    },
    "build": {
      "cmds": [
        "composer install --optimize-autoloader --no-dev --no-interaction",
        "npm install",
        "npm run build"
      ]
    },
    "start": {
      "cmd": "bash start.sh"
    }
  }
}
